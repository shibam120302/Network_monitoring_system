# Copy to .env and fill in values
APP_NAME=Network Monitoring System
DEBUG=false

DATABASE_URL=postgresql://monitor:monitor@localhost:5432/network_monitoring
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@network-monitor.local
ALERT_EMAIL_TO=admin@example.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_LOCAL_LLM=false
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

THRESHOLD_LATENCY_MS=100
THRESHOLD_PACKET_LOSS_PCT=5
THRESHOLD_CPU_PCT=90

METRICS_INTERVAL_SEC=30
CENTRAL_API_URL=http://localhost:8000

NETMIKO_TIMEOUT=30
NETMIKO_DEVICE_TYPE=cisco_ios
